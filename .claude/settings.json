{
  "permissions": {
    "allow": [
      "Bash(node*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git revert*)",
      "Bash(git rev-parse*)",
      "Bash(date*)",
      "Bash(wc*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(cat*)",
      "Bash(echo*)",
      "Bash(chmod*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '🔧 РОБОЧИЙ ПРОЦЕС (CLAUDE.md секція 🔧): 1) Файли >250 рядків → skeleton+Edit (не один Write). 2) Checkpoint-коміт після КОЖНОЇ логічної фази (не чекати кінця). 3) ≤25 слів між tool calls. 📋 ТРИГЕРИ АВТО-АКТИВАЦІЇ СКІЛІВ (_ai-tools/SKILLS_PLAN.md): модалка/стиль/колір/фон → /ux-ui • промпт/галюцинує/OWL_тон → /prompt-engineer • iOS/PWA/Safari/bfcache → /pwa-ios-fix • рефакторинг/розбити_файл/>500 рядків → /refactor-large • Supabase/backend/offline → /supabase-prep. Claude САМ викликає скіл за тригером, не чекає /команди.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_TOOL_INPUT_FILE_PATH\"; if [[ \"$file\" == *.js ]]; then node --check \"$file\" && echo \"✓ синтаксис OK: $file\" || echo \"✗ ПОМИЛКА синтаксису: $file\"; fi"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/cache-name-reminder.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ai-tools-sync.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/md-index-reminder.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/rules-reminder.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/context-warning.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-triggers.sh"
          }
        ]
      }
    ]
  }
}
